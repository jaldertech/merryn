# Copy to .env and fill in. Never commit the real file — the token
# controls your bot.

# Bot token from https://discord.com/developers/applications
DISCORD_TOKEN=

# Your Discord server ID (right-click server name > Copy Server ID).
# Optional but recommended: makes slash commands appear instantly
# instead of taking up to an hour to propagate globally.
GUILD_ID=

# Optional: a role ID whose holders count as meeting moderators.
# Anyone with the Manage Server permission is always a moderator.
MOD_ROLE_ID=

# Optional: where state and minutes are written (default: ./merryn-data)
#DATA_DIR=

# Optional: archive channel for minutes. When a real (non-test) meeting
# ends, a summary and the full Markdown minutes are filed here in addition
# to the meeting's own channel. An explicit ID wins; otherwise the first
# text channel matching the name is used. Leave unset to disable.
#MINUTES_CHANNEL_ID=
#MINUTES_CHANNEL_NAME=minutes

# Optional: your own hold music — a 48 kHz 16-bit WAV, mono or stereo.
#HOLD_MUSIC_FILE=

# Optional: timezone for minutes, timestamps, and the times you give to
# /meeting schedule, e.g. Europe/London or America/New_York (default: the
# machine's local time).
#MERRYN_TIMEZONE=

# Optional: update notifications (default: on). Once a day Merryn asks
# GitHub whether a newer release exists and, if so, logs it and DMs you
# (the application owner) once. It only ever contacts GitHub. Set to off
# to disable entirely.
#MERRYN_UPDATE_CHECK=on
